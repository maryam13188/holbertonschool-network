#!/usr/bin/env bash
# This script configures /etc/hosts to resolve localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Remove any existing lines containing localhost or facebook.com
sudo sed -i '/localhost/d' /etc/hosts
sudo sed -i '/facebook.com/d' /etc/hosts

# Add the new resolution entries
echo "127.0.0.2 localhost" | sudo tee -a /etc/hosts > /dev/null
echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null
